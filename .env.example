PORT = 5000
MONGO_URI = "mongodb://localhost:27017/findash"
FRONTEND_URL = "http://localhost:3000"

# JWT Configuration
JWT_SECRET = "your_jwt_secret_key_change_in_production"
JWT_EXPIRE = "7d"
JWT_REFRESH_SECRET = "your_jwt_refresh_secret_key_change_in_production"
REFRESH_TOKEN_EXPIRE = "30d"

# Admin Configuration
# Change this to a strong secret key for admin registration
# Only people with this secret key can register as admin
ADMIN_SECRET_KEY = "your_admin_secret_key_change_this_in_production"

# Database
NODE_ENV = "development"
